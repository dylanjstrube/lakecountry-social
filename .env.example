# Copy this to .env for local development (never commit .env)

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AI Image Generation (choose one)
FLUX_API_KEY=your_flux_api_key_here
# STABILITY_API_KEY=your_stability_api_key_here

# Meta Graph API
META_PAGE_ACCESS_TOKEN=your_non_expiring_page_access_token
META_PAGE_ID=your_facebook_page_id
META_IG_USER_ID=your_instagram_business_account_id
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# Optional: Facebook Place ID for Delafield, WI (enables location tagging on posts)
# Find via: GET /search?type=place&q=Delafield+WI&fields=name,id in Graph API Explorer
META_DELAFIELD_PLACE_ID=

# Set automatically by Netlify in production; set manually for local dev
URL=http://localhost:8888
